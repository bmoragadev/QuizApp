<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".QuestionFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        >

        <TextView
            android:id="@+id/tvQuestionTitle"
            android:text="Pregunta 1"
            android:textAlignment="center"
            android:textSize="36sp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            />

        <TextView
            android:id="@+id/tvQuestionStatement"
            android:text="Enunciado de la pregunta"
            android:textAlignment="center"
            android:textSize="20sp"
            android:textStyle="italic"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            />


        <Button
            android:id="@+id/btnAnswer1"
            android:text="Respuesta 1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"

            />

        <Button
            android:id="@+id/btnAnswer2"
            android:text="Respuesta 2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"

            />

        <Button
            android:id="@+id/btnAnswer3"
            android:text="Respuesta 3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"

            />

        <Button
            android:id="@+id/btnAnswer4"
            android:text="Respuesta 4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"

            />

        <Button
            android:id="@+id/btnHint"
            android:text="Pista"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:strokeWidth="2dp"
            app:strokeColor="@color/material_dynamic_secondary0"
            android:textColor="@color/black"
            android:backgroundTint="@color/white"


            />



    </LinearLayout>

</ScrollView>